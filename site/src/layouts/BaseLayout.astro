---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'RW Geaston personal website' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <p class="brand"><strong>RW Geaston</strong></p>
        <nav class="nav" aria-label="Main">
          <a href="/">Home</a>
          <a href="/cv">CV</a>
          <a href="/photography">Photography</a>
        </nav>
      </div>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <small>&copy; {new Date().getFullYear()} RW Geaston</small>
    </footer>
  </body>
</html>
