---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="RW Geaston | CV" description="HTML CV for RW Geaston">
  <section class="hero">
    <p class="badge">Curriculum Vitae</p>
    <h1>RW Geaston</h1>
    <p class="muted">Email: hello@rwgeaston.com | Location: United Kingdom</p>
    <p>
      This is the HTML version of your CV. Replace placeholder details with your experience,
      education, and achievements.
    </p>
    <p><a href="/cv/rwgeaston-cv.pdf">Download PDF version</a></p>
  </section>

  <section class="cv-section">
    <h2>Profile</h2>
    <p>
      Short professional summary goes here. Keep this to 3-5 lines focused on what you do best.
    </p>
  </section>

  <section class="cv-section">
    <h2>Experience</h2>
    <article class="card">
      <h3>Role Title - Company</h3>
      <p class="muted">Jan 2022 - Present</p>
      <ul>
        <li>Achievement or responsibility 1</li>
        <li>Achievement or responsibility 2</li>
        <li>Achievement or responsibility 3</li>
      </ul>
    </article>
  </section>

  <section class="cv-section">
    <h2>Education</h2>
    <article class="card">
      <h3>Qualification - Institution</h3>
      <p class="muted">Year</p>
    </article>
  </section>

  <section class="cv-section">
    <h2>Skills</h2>
    <article class="card">
      <p>List your core tools, technologies, and domain strengths.</p>
    </article>
  </section>
</BaseLayout>
