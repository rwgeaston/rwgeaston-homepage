---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="RW Geaston | Photography" description="Wedding photography work">
  <section class="hero">
    <p class="badge">Portfolio</p>
    <h1>Wedding photography</h1>
    <p>
      These pages showcase selected work. Since updates are infrequent, each page is kept simple
      and file-based.
    </p>
  </section>

  <section class="cv-section">
    <h2>Gallery pages</h2>
    <div class="grid">
      <article class="card">
        <h3>Wedding Stories</h3>
        <p class="muted">Long-form sets from full wedding days.</p>
        <p><a href="/photography/weddings">Open page</a></p>
      </article>
      <article class="card">
        <h3>Highlights</h3>
        <p class="muted">Small curated set of hero images.</p>
        <p><a href="/photography/highlights">Open page</a></p>
      </article>
    </div>
  </section>
</BaseLayout>
